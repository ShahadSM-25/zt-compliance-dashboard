# =============================================================================
# HealthComply Dashboard — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=mysql://healthcomply:healthcomply_pass@localhost:3306/healthcomply

# ── Auth (Manus OAuth) ────────────────────────────────────────────────────────
# MANUS_OAUTH_CLIENT_ID=your_client_id
# MANUS_OAUTH_CLIENT_SECRET=your_client_secret

# ── Compliance Engine Integration ─────────────────────────────────────────────
# Set this to the absolute path of the cloud-compliance-automation directory.
# When set, the dashboard will run the REAL compliance engine instead of mock.
# Leave unset to use mock mode (safe for local development and demos).
#
# Example (local dev):
#   COMPLIANCE_ENGINE_PATH=/home/ubuntu/cloud-compliance-automation
#
# Example (Docker Compose — already set in docker-compose.yml):
#   COMPLIANCE_ENGINE_PATH=/engine
#
COMPLIANCE_ENGINE_PATH=

# Explicitly enable/disable real engine (overrides COMPLIANCE_ENGINE_PATH check)
# USE_REAL_ENGINE=true
